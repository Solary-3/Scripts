Trail1_317.Attachment1= Attachment1_318
local weld1=CreateWeld(Orb1_311,Orb1_311,HumanoidRootPart,cf(0,0,-30),cf())
local weld2=CreateWeld(Orb2_309,Orb2_309,HumanoidRootPart,cf(0,0,30),cf())

local WhiteColor={}
local BlackColor={}
for _,f in foldah:GetDescendants() do 
  if f:IsA("ParticleEmitter") or f:IsA("Trail") then 
    local white=cs({csk(0.000000,c3(1.000000,1.000000,1.000000)),csk(1.000000,c3(1.000000,1.000000,1.000000))})
    local black=cs({csk(0.000000,c3(0.000000,0.000000,0.000000)),csk(1.000000,c3(0.000000,0.000000,0.000000))})
    if f.Color==white then 
      tinsert(WhiteColor,f)
    elseif f.Color==black then
      tinsert(BlackColor,f)
    end
  end
end
con1=p:GetPropertyChangedSignal("Value"):Connect(function()
  for _,e in foldah:GetDescendants() do 
    if e:IsA("ParticleEmitter") then
      e:Emit(e:GetAttribute("EmitCount"))
    end
  end
end)
local RotDt=1
while foldah do 
if not foldah then con1:Disconnect() break end

for _,b in next,WhiteColor do 
  b.Color=cs{
    csk(0,ig(p,"Value")),
    csk(1,ig(p,"Value")),
  }
end
for _,b in next,BlackColor do 
  b.Color=cs{
    csk(0,ig(s,"Value")),
    csk(1,ig(s,"Value")),
  }
end

weld1.C0=cf(0,0,-30)*angles(0,rad(RotDt*10),0)
weld2.C0=cf(0,0,30)*angles(0,rad(RotDt*10),0)


RotDt+=1
oswait()
end



end

repeat Asset() task.wait() until not char:FindFirstChild(Name.."Assets")
