while foldah do 
if not foldah then att:Destroy() break end
pcall(function()
for _,e in att:GetDescendants() do 
  if e:IsA("Beam") or e:IsA("ParticleEmitter") then 
    e.Color=cs{
      csk(0,ig(s,"Value")),
      csk(1,ig(p,"Value")),
    }
    end
end
end)
oswait()
end




end

repeat Asset() task.wait() until not char:FindFirstChild(Name.."Assets")