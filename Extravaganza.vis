local AssetEssen=(getgenv and getgenv()) or shared

function BetterTween(obj, speed, prop)
local Tinfo=TweenInfo.new
local TweenService=game.TweenService
local hii=Tinfo(speed, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
return TweenService:Create(obj, hii,prop)
end

local t=AssetEssen.Tbls or {}

local block=t.block or nil
local sphere=t.sphere or nil
local square=t.square or nil
local wave1=t.wave1 or nil
local wave2=t.wave2 or nil
local wave3=t.wave3 or nil
local wave4=t.wave4 or nil
